{
  "name": "stock-bot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js",
    "server": "npm install && node -e \"require('fs').mkdirSync('logs',{recursive:true})\" && npx pm2 startOrReload ecosystem.config.cjs --update-env",
    "server:stop": "npx pm2 stop stock-bot",
    "server:restart": "npx pm2 restart stock-bot --update-env",
    "server:logs": "npx pm2 logs stock-bot",
    "server:status": "npx pm2 status stock-bot",
    "server:save": "npx pm2 save",
    "server:resurrect": "npx pm2 resurrect",
    "server:startup:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-pm2-startup-windows.ps1",
    "server:repair:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/repair-pm2-windows.ps1",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^16.6.1",
    "telegraf": "^4.16.3",
    "yahoo-finance2": "^3.14.0"
  },
  "devDependencies": {
    "pm2": "^7.0.1"
  }
}
